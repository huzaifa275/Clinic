# GEMINI_API_KEY: Required for the AI Assistant service.
# Configure this in the environment secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this application is hosted.
# Injected at runtime or set manually to the service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
